  "video_subtitle_readability": {
    "strategy": "暗色背景上白字字幕的可读性保障 — 双层保护方案（阴影 + 背景半透明遮罩）",
    "presets": {
      "default": {
        "mode": "drop_shadow_only",
        "text_shadow": {
          "color": "#000000",
          "alpha": 0.80,
          "offset_x": 1,
          "offset_y": 1,
          "blur_radius": 3
        },
        "background": "无 — 纯阴影方案，不遮挡视频画面",
        "適用场景": "视频播放区字幕（全屏/宽屏模式下）"
      },
      "high_contrast": {
        "mode": "shadow_plus_overlay",
        "text_shadow": {
          "color": "#000000",
          "alpha": 0.90,
          "offset_x": 1,
          "offset_y": 1,
          "blur_radius": 3
        },
        "background_overlay": {
          "color": "#000000",
          "alpha": 0.50,
          "border_radius": 4,
          "padding_horizontal": 8,
          "padding_vertical": 2
        },
        "適用场景": "视频画面亮色区域较多时，阴影可能不足以保证可读性"
      },
      "sentence_focus": {
        "mode": "overlay_only",
        "background_overlay": {
          "color": "#000000",
          "alpha": 0.50,
          "border_radius": 8,
          "padding_horizontal": 12,
          "padding_vertical": 6
        },
        "text_shadow": "无（背景遮罩已足够）",
        "適用场景": "跟读模式当前句高亮展示 — 句子在独立遮罩区内显示"
      }
    },
    "implementation_note": "方案选择逻辑：默认使用 drop_shadow_only 最小化遮挡 -> 检测视频画面brightness过高时自动切换至 high_contrast -> 跟读模式强制使用 sentence_focus。字幕区域位于视频画面底部1/4区域。",
    "dynamic_brightness_detection": "v2可选：对当前帧底部1/4区域采样平均亮度，若Luma>180则自动从 default 切换到 high_contrast 方案"
  },

  "recording_button_visual_states": {
    "strategy": "一个大圆钮表达所有录音状态，通过颜色转换 + 微动效传递状态语义，避免冗余文字标签",
    "base_specs": {
      "diameter": 72,
      "diameter_dp": 72,
      "shape": "圆形 (Circle)",
      "icon_size": 28,
      "interaction": "Push-to-Talk — 按住开始/松开即停"
    },
    "states": [
      {
        "state": "idle (待机)",
        "trigger": "初始状态 / 录音完成后复位",
        "appearance": {
          "background_color": "#6C9FFF",
          "icon": "mic (麦克风)",
          "icon_color": "#FFFFFF",
          "elevation": 4,
          "scale": 1.0,
          "animations": "无"
        }
      },
      {
        "state": "recording (录音中)",
        "trigger": "用户长按按住",
        "appearance": {
          "background_color": "#F44336",
          "icon": "mic (麦克风)",
          "icon_color": "#FFFFFF",
          "elevation": 8,
          "scale": 1.05,
          "animations": [
            {
              "type": "pulse_ring",
              "description": "从按钮向外扩散的脉冲环，半径从 72dp 扩大到 120dp 再回缩",
              "ring_color": "#F44336",
              "ring_alpha_start": 0.30,
              "ring_alpha_end": 0.0,
              "duration_ms": 1200,
              "repeat": "infinite",
              "easing": "ease-out"
            },
            {
              "type": "ripple_on_press",
              "description": "水波涟漪动效表示正在拾音",
              "origin": "手指按压点"
            }
          ]
        }
      },
      {
        "state": "completed (完成)",
        "trigger": "松开手指，录音成功保存",
        "appearance": {
          "background_color": "#4CAF50",
          "icon": "check_circle (勾选圆圈)",
          "icon_color": "#FFFFFF",
          "elevation": 2,
          "scale": 1.0,
          "animations": [
            {
              "type": "success_pop",
              "description": "短暂缩放到1.1x再回弹到1.0x，表示成功完成",
              "duration_ms": 300,
              "easing": "spring"
            }
          ],
          "auto_transition": "录音完成后保持 completed 状态2秒，然后自动回到 idle"
        }
      },
      {
        "state": "error (错误)",
        "trigger": "录音失败（权限拒绝/存储失败等）",
        "appearance": {
          "background_color": "#F44336",
          "icon": "error_outline (警告三角)",
          "icon_color": "#FFFFFF",
          "animations": [
            {
              "type": "shake",
              "description": "水平抖动动效表示异常",
              "duration_ms": 400,
              "amplitude": 4
            }
          ],
          "auto_transition": "保持 error 状态直到用户操作（点击重试按钮）"
        }
      }
    ],
    "accessory_indicators": {
      "recording_timer": {
        "visible_when": "recording 状态",
        "position": "按钮正上方",
        "typography": "body_medium",
        "format": "MM:SS / SS.s",
        "color": "#F44336"
      },
      "recording_waveform": {
        "visible_when": "recording 状态",
        "position": "按钮与句子文本之间",
        "description": "实时音频波形可视化，高度约 40dp，颜色 #6C9FFF",
        "implementation": "AudioRecord.getMaxAmplitude() 驱动的 Compose Canvas 自绘"
      }
    }
  },

